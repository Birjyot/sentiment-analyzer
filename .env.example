# ==============================================================================
# StockSentimentIQ - API Keys Configuration
# ==============================================================================
# Copy this file to .env and fill in your actual API keys.
# NEVER commit your .env file to version control.
# ==============================================================================

# [REQUIRED] Groq API Key for AI Insights (LLaMA 3.3 70B)
# Get a free key at: https://console.groq.com/keys
GROQ_API_KEY="your_groq_api_key_here"

# [RECOMMENDED] Finnhub API Key for Real-time Quotes & Live News
# Get a free key at: https://finnhub.io/
FINNHUB_API_KEY="your_finnhub_api_key_here"

# [RECOMMENDED] Alpha Vantage API Key for Historical OHLC Candlestick data
# Get a free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY="your_alpha_vantage_api_key_here"

# [OPTIONAL] NewsAPI Key for broader market news (Fallback)
# Get a free key at: https://newsapi.org/
NEWS_API_KEY="your_news_api_key_here"
